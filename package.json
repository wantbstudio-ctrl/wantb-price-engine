{
  "name": "wantb-price-engine",
  "version": "1.0.3",
  "private": true,
  "main": "electron/main.cjs",
  "description": "WantB Price Engine",
  "author": "WantB",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "electron-dev": "concurrently \"next dev -p 3000\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "dist": "npm run build && electron-builder",
    "lint": "next lint"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "next": "^14.2.5",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.1",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.wantb.priceengine",
    "productName": "WantB Price Engine",
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/**/*",
      "app/**/*",
      "components/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json",
      "next.config.js",
      "next.config.mjs"
    ],
    "extraResources": [
      {
        "from": "icons",
        "to": "icons"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/wantb.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
