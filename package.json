{
  "name": "wantb-price-engine",
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "private": true,

  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",

    "electron": "electron .",
    "electron-dev": "concurrently \"next dev -p 3000\" \"wait-on http://localhost:3000 && electron .\"",

    "dist": "npm run build && electron-builder"
  },

  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "next": "14.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },

  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "wait-on": "^7.0.1"
  },

  "build": {
    "appId": "com.wantb.priceengine",
    "productName": "WantB Price Engine",
    "icon": "icons/wantb.ico",

    "directories": {
      "output": "dist"
    },

    "files": [
      "electron/**/*",
      ".next/**/*",
      "package.json"
    ],

    "win": {
      "target": "nsis",
      "icon": "icons/wantb.ico"
    }
  }
}